APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# Photo Storage Drivers (pick ONE via admin Settings -> Photo Storage)
# Leave empty if not using — only the active driver needs configuration.
# ----------------------------------------------------------------------------

# AWS S3 (industry-standard object storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 (S3-compatible, zero egress fees — recommended for scale)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# Cloudinary (managed CDN with automatic image optimization)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=matrimony/photos

VITE_APP_NAME="${APP_NAME}"

# Sanctum API tokens expire after 90 days (in minutes: 60*24*90 = 129600)
SANCTUM_EXPIRATION=129600

# ----------------------------------------------------------------------------
# Firebase Cloud Messaging (push notifications) — kreait/laravel-firebase
# Download the service-account JSON from Firebase Console
#   → Project Settings → Service Accounts → Generate New Private Key
# Save it to storage/app/firebase-credentials.json (already in .gitignore).
# Leaving FIREBASE_CREDENTIALS empty disables push (the app still runs fine).
# ----------------------------------------------------------------------------
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json

# ----------------------------------------------------------------------------
# Matri ID prefix — appears in the user's display matri-id (e.g. KM100042).
# Change once per deployment; never re-rotate (would break existing IDs).
# ----------------------------------------------------------------------------
MATRI_ID_PREFIX=AM

# ----------------------------------------------------------------------------
# Payment gateways — fill in the ones you plan to enable in admin Settings
# → Payment Gateways. Leave others empty; the controller raises
# GATEWAY_NOT_CONFIGURED 422 with a clear message if a buyer hits an
# unconfigured gateway.
#
# Razorpay test creds prefix with `rzp_test_*`; live creds with `rzp_live_*`.
# Stripe test creds prefix with `sk_test_*` / `pk_test_*`.
# PayPal: MODE=sandbox uses developer test environment.
# Paytm + PhonePe ship MID/MERCHANT_KEY pairs from their dashboards.
# ----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_CURRENCY=USD

PAYTM_MODE=staging
PAYTM_MID=
PAYTM_MERCHANT_KEY=
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_CHANNEL_ID=WEB
PAYTM_WEBSITE=WEBSTAGING

PHONEPE_MODE=sandbox
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
PHONEPE_WEBHOOK_USERNAME=
PHONEPE_WEBHOOK_PASSWORD=

# ----------------------------------------------------------------------------
# Scribe API documentation — optional. Set to a long random string to enable
# the "Try It Out" feature in /docs against your live API. Leave empty in
# production (Scribe falls back to a placeholder).
# ----------------------------------------------------------------------------
SCRIBE_AUTH_KEY=
