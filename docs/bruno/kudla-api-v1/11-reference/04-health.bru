meta {
  name: GET /health
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/v1/health
  body: none
  auth: none
}

docs {
  Liveness probe. Should respond 200 with status=ok. Useful as the very
  first request when wiring up a new environment to confirm baseUrl,
  DNS, and basic routing are sane before fanning out into auth flows.
}

tests {
  test("status is 200", () => {
    expect(res.status).to.equal(200);
  });
  test("envelope success=true", () => {
    expect(res.body.success).to.equal(true);
  });
  test("payload reports data.status=ok", () => {
    expect(res.body.data).to.have.property("status");
    expect(res.body.data.status).to.equal("ok");
  });
  test("payload reports data.version=v1", () => {
    expect(res.body.data.version).to.equal("v1");
  });
}
