meta {
  name: POST /settings/hide
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/settings/hide
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  Toggles profile to hidden. Idempotent — re-running on an already
  hidden profile still returns 200 with is_hidden=true.
}

tests {
  test("status is 200", () => {
    expect(res.status).to.equal(200);
  });
  test("envelope success=true", () => {
    expect(res.body.success).to.equal(true);
  });
  test("response confirms is_hidden=true", () => {
    expect(res.body.data).to.have.property("is_hidden");
    expect(res.body.data.is_hidden).to.equal(true);
  });
}
