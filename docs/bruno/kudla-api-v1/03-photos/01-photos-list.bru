meta {
  name: GET /photos (own)
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/photos
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("status is 200", () => {
    expect(res.status).to.equal(200);
  });
  test("envelope success=true", () => {
    expect(res.body.success).to.equal(true);
  });
  test("data is an array (possibly empty for fresh user)", () => {
    expect(res.body.data).to.be.an("array");
  });
}
