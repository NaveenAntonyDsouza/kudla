* text=auto eol=lf

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore

# ---------------------------------------------------------------------------
# Generated / vendored artifacts — GitHub collapses these in the PR diff view
# (linguist-generated) and excludes them from language-stats (linguist-vendored).
# They are still committed so a fresh clone doesn't require composer install +
# scribe:generate before /docs is browsable, but reviewers don't have to
# scroll past 30k lines of generated HTML to find the actual code changes.
# ---------------------------------------------------------------------------
resources/views/scribe/**       linguist-generated=true
public/vendor/scribe/**         linguist-generated=true linguist-vendored=true
storage/app/private/scribe/**   linguist-generated=true
composer.lock                   linguist-generated=true
package-lock.json               linguist-generated=true
yarn.lock                       linguist-generated=true
